{
  "name": "@algoledger/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.injected.config.ts && vite build",
    "lint": "eslint . --ignore-pattern public/**",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@algoledger/adapters": "workspace:*",
    "@algoledger/config": "workspace:*",
    "@algoledger/generators": "workspace:*",
    "@algoledger/github": "workspace:*",
    "@algoledger/schemas": "workspace:*",
    "@algoledger/shared": "workspace:*",
    "@algoledger/ui": "workspace:*",
    "d3-hierarchy": "^3.1.2",
    "framer-motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/chrome": "^0.2.2",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
